{
  "version": 2,
  "name": "nastenka-ai",
  "builds": [
    {
      "src": "src/api.ts",
      "use": "@vercel/node"
    },
    {
      "src": "dashboard/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/sse",
      "destination": "/src/api.ts"
    },
    {
      "source": "/api/(.*)",
      "destination": "/src/api.ts"
    },
    {
      "source": "/messages",
      "destination": "/src/api.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/dashboard/$1"
    }
  ]
}
